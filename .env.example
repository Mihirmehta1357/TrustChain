# -----------------------------------------------------------------------------
# TrustChain Environment Variables
# -----------------------------------------------------------------------------

# Supabase Credentials (Off-Chain Database)
# You can find these in your Supabase Dashboard under: Project Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=ey...your-long-anon-api-key...

# Hardhat Local Network (On-Chain RPC)
# Leave this to localhost for local testing
VITE_RPC_URL=http://127.0.0.1:8545
